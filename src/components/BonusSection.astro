---
const bonuses = [
  {
    title: 'Pack Amigos de Kitty',
    description: 'Aprende a tejer a la gatita más famosa del mundo y sus adorables amigos.',
    image: '/images/bono-kitty.webp'
  },
  {
    title: 'Pack Gatitos Halloween',
    description: 'Diseños temáticos de gatitos disfrazados, ideales para vender en temporada.',
    image: '/images/bono-halloween.webp'
  },
  {
    title: 'Pack Gatitos Cactus',
    description: 'La combinación perfecta entre plantas y mascotas que está en tendencia.',
    image: '/images/bono-cactus.webp'
  }
];
---

<section class="py-24 bg-primary-600 text-white overflow-hidden relative">
  <!-- Fondo decorativo -->
  <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 rounded-full bg-primary-500 blur-3xl opacity-50"></div>
  <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 rounded-full bg-primary-700 blur-3xl opacity-50"></div>
  
  <div class="container mx-auto px-4 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block px-4 py-1 rounded-full bg-primary-500 text-white text-sm font-bold tracking-wider mb-4 border border-primary-400">EXCLUSIVO</span>
      <h2 class="text-3xl md:text-5xl font-display font-extrabold text-white mb-6">Bonos de Regalo Incluidos</h2>
      <p class="text-lg text-primary-100">Lleva tu emprendimiento al siguiente nivel con estas guías adicionales totalmente gratuitas al adquirir el ebook.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {bonuses.map((bonus) => (
        <div class="bg-primary-700/50 backdrop-blur-sm border border-primary-500/30 p-6 rounded-3xl hover:bg-primary-700 transition-colors flex flex-col items-center text-center">
          <div class="w-full aspect-[3/4] mb-6 rounded-2xl overflow-hidden shadow-lg border border-primary-400/20">
            <img src={bonus.image} alt={bonus.title} class="w-full h-full object-cover" />
          </div>
          <h3 class="text-2xl font-bold text-white mb-3">{bonus.title}</h3>
          <p class="text-primary-100">{bonus.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
