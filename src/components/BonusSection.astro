---
const bonuses = [
  {
    title: 'Pack Amigos de Kitty',
    description: 'Aprende a tejer a la gatita más famosa del mundo y sus adorables amigos.',
    icon: 'M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1M4 7l2-1M4 7l2 1M4 7v2.5M12 21l-2-1m2 1l2-1m-2 1v-2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5'
  },
  {
    title: 'Pack Gatitos Halloween',
    description: 'Diseños temáticos de gatitos disfrazados, ideales para vender en temporada.',
    icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253'
  },
  {
    title: 'Pack Gatitos Cactus',
    description: 'La combinación perfecta entre plantas y mascotas que está en tendencia.',
    icon: 'M12 2v20m0 0l-3-3m3 3l3-3'
  }
];
---

<section class="py-24 bg-primary-600 text-white overflow-hidden relative">
  <!-- Fondo decorativo -->
  <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 rounded-full bg-primary-500 blur-3xl opacity-50"></div>
  <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 rounded-full bg-primary-700 blur-3xl opacity-50"></div>
  
  <div class="container mx-auto px-4 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block px-4 py-1 rounded-full bg-primary-500 text-white text-sm font-bold tracking-wider mb-4 border border-primary-400">EXCLUSIVO</span>
      <h2 class="text-3xl md:text-5xl font-display font-extrabold mb-6">Bonos de Regalo Incluidos</h2>
      <p class="text-lg text-primary-100">Lleva tu emprendimiento al siguiente nivel con estas guías adicionales totalmente gratuitas al adquirir el ebook.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {bonuses.map((bonus) => (
        <div class="bg-primary-700/50 backdrop-blur-sm border border-primary-500/30 p-8 rounded-3xl hover:bg-primary-700 transition-colors">
          <div class="w-14 h-14 bg-white/10 rounded-2xl flex items-center justify-center mb-6 text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d={bonus.icon} />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">{bonus.title}</h3>
          <p class="text-primary-100">{bonus.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
