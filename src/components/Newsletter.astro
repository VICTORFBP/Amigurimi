---
---

<section class="py-20 bg-white relative overflow-hidden">
  {/* Decorative elements */}
  <div class="absolute -top-24 -left-24 w-96 h-96 bg-primary-100 rounded-full blur-3xl opacity-40"></div>
  <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-secondary-100 rounded-full blur-3xl opacity-40"></div>

  <div class="container mx-auto px-4 max-w-4xl relative z-10">
    <div class="bg-gradient-to-br from-primary-600 to-primary-700 rounded-3xl p-8 md:p-12 text-white shadow-xl relative overflow-hidden border border-primary-500/30">
      {/* Decorative pattern inside the box */}
      <div class="absolute inset-0 bg-grid-white/[0.05] [mask-image:linear-gradient(0deg,white,transparent)] pointer-events-none"></div>

      <div class="relative z-10 flex flex-col md:flex-row items-center gap-8 md:gap-12">
        <div class="md:w-1/2 flex flex-col items-start text-left">
          <span class="inline-block px-3 py-1 rounded-full bg-primary-500 text-white text-xs font-bold tracking-wider mb-4 border border-primary-400">REGALO GRATUITO</span>
          <h2 class="text-3xl font-display font-extrabold mb-4 leading-tight">
            ¿Quieres tejer tu primer Amigurumi hoy?
          </h2>
          <p class="text-primary-100 text-sm leading-relaxed mb-6">
            Suscríbete a nuestro boletín semanal y recibe gratis en tu correo el **Patrón PDF de la Mascota Conejito Orejón** + guías exclusivas de crochet.
          </p>
          <div class="flex items-center gap-2 text-xs text-primary-200">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Cero Spam. Cancela tu suscripción cuando quieras.</span>
          </div>
        </div>

        <div class="md:w-1/2 w-full">
          <form id="newsletter-form" class="flex flex-col gap-4 bg-primary-800/40 p-6 md:p-8 rounded-2xl border border-primary-500/20 backdrop-blur-sm">
            <div>
              <label for="newsletter-name" class="block text-xs font-bold text-primary-200 mb-2 uppercase tracking-wide">Tu Nombre</label>
              <input 
                type="text" 
                id="newsletter-name" 
                required 
                placeholder="Ej. María" 
                class="w-full px-4 py-3 rounded-xl bg-white text-slate-800 border border-transparent focus:border-accent focus:ring-0 outline-none text-sm placeholder-slate-400 font-medium transition-all"
              />
            </div>
            
            <div>
              <label for="newsletter-email" class="block text-xs font-bold text-primary-200 mb-2 uppercase tracking-wide">Correo Electrónico</label>
              <input 
                type="email" 
                id="newsletter-email" 
                required 
                placeholder="ejemplo@correo.com" 
                class="w-full px-4 py-3 rounded-xl bg-white text-slate-800 border border-transparent focus:border-accent focus:ring-0 outline-none text-sm placeholder-slate-400 font-medium transition-all"
              />
            </div>

            <button 
              type="submit" 
              class="w-full py-4 bg-accent hover:bg-amber-400 text-primary-950 font-bold rounded-xl transition-all shadow-md hover:shadow-lg cursor-pointer transform active:scale-95 text-center mt-2 flex items-center justify-center gap-2"
            >
              <span>¡Enviar Patrón PDF Gratis!</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </button>
          </form>

          {/* Success Message */}
          <div id="newsletter-success" class="hidden bg-emerald-500/10 border border-emerald-500/30 p-6 md:p-8 rounded-2xl text-center text-white backdrop-blur-sm flex flex-col items-center gap-4">
            <div class="w-12 h-12 bg-emerald-500 rounded-full flex items-center justify-center shadow-lg shadow-emerald-500/20 text-white animate-bounce">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h3 class="text-xl font-bold mb-2">¡Suscripción Exitosa!</h3>
              <p class="text-slate-200 text-sm leading-relaxed">
                ¡Tu patrón PDF está en camino! Revisa tu bandeja de entrada (y la carpeta de spam o promociones) en los próximos 2 minutos.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('newsletter-form');
  const successMessage = document.getElementById('newsletter-success');

  if (form && successMessage) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const nameInput = document.getElementById('newsletter-name') as HTMLInputElement;
      const emailInput = document.getElementById('newsletter-email') as HTMLInputElement;

      if (nameInput.value && emailInput.value) {
        // Simulate API call
        const submitBtn = form.querySelector('button');
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.innerHTML = '<span>Enviando...</span>';
        }

        setTimeout(() => {
          form.classList.add('hidden');
          successMessage.classList.remove('hidden');
        }, 1200);
      }
    });
  }
</script>
