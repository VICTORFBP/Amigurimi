---
const navItems = [
  { label: 'Inicio', href: '/' },
  { label: 'Patrones de Mascotas', href: '/ebook-patrones-mascotas' },
  { label: 'Nosotros', href: '/nosotros' }
];
---

<header class="sticky top-0 z-50 w-full glass">
  <div class="container mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2">
      <span class="text-2xl font-display font-bold text-primary-600 tracking-tight">Amigurumi<span class="text-accent">Pets</span></span>
    </a>
    
    <nav class="hidden md:flex items-center gap-6">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class="text-sm font-medium text-slate-600 hover:text-primary-600 transition-colors"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-4">
      <a 
        href="/ebook-patrones-mascotas" 
        class="hidden sm:inline-flex items-center justify-center px-5 py-2 text-sm font-medium text-white bg-primary-500 rounded-full hover:bg-primary-600 transition-all shadow-md hover:shadow-lg transform hover:-translate-y-0.5"
      >
        Ver Patrones
      </a>
      
      <!-- Mobile menu button -->
      <button class="md:hidden p-2 text-slate-600">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>
</header>
