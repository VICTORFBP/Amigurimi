---
interface Props {
  limit?: number;
  showFilters?: boolean;
  title?: string;
  subtitle?: string;
}

const { 
  limit, 
  showFilters = true,
  title = "Algunos Diseños Incluidos",
  subtitle = "Más de 60 patrones de mascotas que podrás tejer desde el primer día. Aquí te mostramos una selección exclusiva."
} = Astro.props;

const patterns = [
  { name: 'Perrito Golden', category: 'Perros', image: '/images/gallery-1.webp', difficulty: 'Fácil', size: '15 cm', hook: '2.5 mm' },
  { name: 'Gatito Siames', category: 'Gatos', image: '/images/gallery-2.webp', difficulty: 'Fácil', size: '12 cm', hook: '2.0 mm' },
  { name: 'Conejito Orejón', category: 'Mascotas', image: '/images/gallery-3.webp', difficulty: 'Fácil', size: '18 cm', hook: '3.0 mm' },
  { name: 'Bulldog Francés', category: 'Perros', image: '/images/gallery-4.webp', difficulty: 'Intermedio', size: '14 cm', hook: '2.5 mm' },
  { name: 'Gato Persa', category: 'Gatos', image: '/images/gallery-5.webp', difficulty: 'Fácil', size: '13 cm', hook: '2.0 mm' },
  { name: 'Loro Multicolor', category: 'Aves', image: '/images/gallery-6.webp', difficulty: 'Intermedio', size: '16 cm', hook: '2.5 mm' },
];

const displayedPatterns = limit ? patterns.slice(0, limit) : patterns;
const uniqueCategories = ['Todos', ...new Set(patterns.map(p => p.category))];
---

<section class="py-24 bg-slate-50 relative overflow-hidden">
  <!-- Subtle decorative elements -->
  <div class="absolute top-0 left-0 w-96 h-96 bg-primary-100/50 rounded-full blur-3xl opacity-30 transform -translate-x-1/2 -translate-y-1/2"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-secondary-100/50 rounded-full blur-3xl opacity-30 transform translate-x-1/2 translate-y-1/2"></div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-12">
      <h2 class="text-3xl md:text-5xl font-display font-extrabold text-slate-900 mb-6">{title}</h2>
      <p class="text-lg text-slate-600 leading-relaxed">{subtitle}</p>
    </div>
    
    {showFilters && !limit && (
      <!-- Interactive Filter Tabs -->
      <div class="flex flex-wrap justify-center gap-2 mb-12" id="gallery-filter-tabs">
        {uniqueCategories.map((category, idx) => (
          <button
            type="button"
            data-category={category}
            class={`px-6 py-2.5 rounded-full text-sm font-semibold transition-all duration-300 cursor-pointer ${
              idx === 0 
                ? 'bg-primary-600 text-white shadow-md shadow-primary-500/20' 
                : 'bg-white text-slate-600 border border-slate-200 hover:border-primary-300 hover:text-primary-600 shadow-sm'
            }`}
          >
            {category}
          </button>
        ))}
      </div>
    )}

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8" id="patterns-grid">
      {displayedPatterns.map((item) => (
        <div 
          class="pattern-card group bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 transform hover:-translate-y-1.5 border border-slate-100/80 flex flex-col h-full"
          data-category={item.category}
        >
          {/* Image Container with Hover Zoom & Overlay */}
          <div class="relative aspect-square overflow-hidden bg-slate-100">
            <img 
              src={item.image} 
              alt={`Patrón amigurumi de ${item.name}`} 
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
              onerror="this.src='data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22400%22%20height%3D%22400%22%20viewBox%3D%220%200%20400%20400%22%3E%3Crect%20fill%3D%22%23f1f5f9%22%20width%3D%22400%22%20height%3D%22400%22%2F%3E%3Ctext%20fill%3D%22%2394a3b8%22%20font-family%3D%22sans-serif%22%20font-size%3D%2220%22%20dy%3D%2210.5%22%20font-weight%3D%22bold%22%20x%3D%2250%25%22%20y%3D%2250%25%22%20text-anchor%3D%22middle%22%3EImagen%20de%20Patr%C3%B3n%3C%2Ftext%3E%3C%2Fsvg%3E'"
            />
            {/* Category Tag */}
            <div class="absolute top-4 left-4">
              <span class="px-3 py-1 text-xs font-bold bg-white/90 backdrop-blur-sm text-primary-700 rounded-full shadow-sm">
                {item.category}
              </span>
            </div>
            
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
              <span class="text-white text-sm font-medium">Incluido en el Ebook</span>
            </div>
          </div>
          
          {/* Card Body */}
          <div class="p-6 flex flex-col flex-grow">
            <h3 class="text-xl font-bold text-slate-900 mb-4 group-hover:text-primary-600 transition-colors">
              {item.name}
            </h3>
            
            {/* Technical Metadata */}
            <div class="grid grid-cols-3 gap-2 py-4 border-t border-slate-100 mt-auto text-center">
              <div class="flex flex-col">
                <span class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Dificultad</span>
                <span class={`text-xs font-semibold mt-1 px-1.5 py-0.5 rounded-full inline-block ${
                  item.difficulty === 'Fácil' 
                    ? 'bg-green-50 text-green-700' 
                    : 'bg-amber-50 text-amber-700'
                }`}>
                  {item.difficulty}
                </span>
              </div>
              <div class="flex flex-col border-x border-slate-100">
                <span class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Medida</span>
                <span class="text-xs font-semibold text-slate-700 mt-1">{item.size}</span>
              </div>
              <div class="flex flex-col">
                <span class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Aguja</span>
                <span class="text-xs font-semibold text-slate-700 mt-1">{item.hook}</span>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <div class="mt-16 text-center flex flex-col sm:flex-row justify-center items-center gap-4">
      {limit && (
        <a 
          href="/ebook-patrones-mascotas" 
          class="inline-flex justify-center items-center px-8 py-4 text-lg font-bold text-white bg-primary-600 rounded-full hover:bg-primary-700 transition-all shadow-lg hover:shadow-primary-500/20 transform hover:-translate-y-0.5 w-full sm:w-auto"
        >
          Ver todos los diseños
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </a>
      )}
      
      <a 
        href="https://drive.google.com/file/d/1t2DCK2YGbLEBw5vgXG2oYN5o0Nm9LL18/view" 
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex justify-center items-center px-8 py-4 text-lg font-bold text-slate-700 bg-white border-2 border-slate-200 rounded-full hover:bg-slate-50 hover:border-slate-300 transition-colors w-full sm:w-auto"
      >
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
        Descargar Catálogo PDF
      </a>
    </div>
  </div>
</section>

{showFilters && !limit && (
  <script>
    // Client-side filtering logic
    const filterTabsContainer = document.getElementById('gallery-filter-tabs');
    const cards = document.querySelectorAll('.pattern-card');

    if (filterTabsContainer && cards.length > 0) {
      const buttons = filterTabsContainer.querySelectorAll('button');
      
      buttons.forEach(button => {
        button.addEventListener('click', () => {
          // Remove active styles from all buttons
          buttons.forEach(btn => {
            btn.classList.remove('bg-primary-600', 'text-white', 'shadow-md', 'shadow-primary-500/20');
            btn.classList.add('bg-white', 'text-slate-600', 'border', 'border-slate-200', 'hover:border-primary-300', 'hover:text-primary-600', 'shadow-sm');
          });

          // Add active styles to clicked button
          button.classList.add('bg-primary-600', 'text-white', 'shadow-md', 'shadow-primary-500/20');
          button.classList.remove('bg-white', 'text-slate-600', 'border', 'border-slate-200', 'hover:border-primary-300', 'hover:text-primary-600', 'shadow-sm');

          const targetCategory = button.getAttribute('data-category');

          cards.forEach(card => {
            const cardCategory = card.getAttribute('data-category');
            const cardElement = card as HTMLElement;

            if (targetCategory === 'Todos' || cardCategory === targetCategory) {
              cardElement.style.display = 'flex';
              // Trigger slight fade-in animation
              cardElement.style.opacity = '0';
              setTimeout(() => {
                cardElement.style.transition = 'opacity 400ms ease, transform 500ms ease';
                cardElement.style.opacity = '1';
              }, 10);
            } else {
              cardElement.style.display = 'none';
            }
          });
        });
      });
    }
  </script>
)}

