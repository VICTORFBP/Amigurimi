---
const testimonials = [
  {
    name: 'María García',
    role: 'Principiante',
    text: 'Nunca había tejido nada en mi vida. Las instrucciones son tan claras que mi primer perrito quedó hermoso. ¡Ya estoy haciendo el segundo!',
    image: 'https://i.pravatar.cc/150?img=1'
  },
  {
    name: 'Laura Sánchez',
    role: 'Emprendedora',
    text: 'Estos patrones me ayudaron a iniciar mi negocio de mascotas personalizadas. Los diseños son únicos y los clientes los aman.',
    image: 'https://i.pravatar.cc/150?img=5'
  },
  {
    name: 'Carmen Ruiz',
    role: 'Tejedora Experta',
    text: 'Llevo años tejiendo y estos son los mejores patrones en español que he encontrado. Las fotos paso a paso valen cada centavo.',
    image: 'https://i.pravatar.cc/150?img=9'
  }
];
---

<section class="py-24 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-5xl font-display font-extrabold text-slate-900 mb-6">Lo que dicen nuestras tejedoras</h2>
      <p class="text-lg text-slate-600">Miles de mujeres ya están creando sus propias mascotas y generando ingresos.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map((testimonial) => (
        <div class="bg-slate-50 p-8 rounded-3xl border border-slate-100 relative">
          <!-- Quote Icon -->
          <div class="text-primary-200 absolute top-6 right-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="currentColor"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
          </div>
          
          <div class="flex items-center gap-4 mb-6 relative z-10">
            <img src={testimonial.image} alt={testimonial.name} class="w-16 h-16 rounded-full border-2 border-white shadow-sm" />
            <div>
              <h4 class="font-bold text-slate-900">{testimonial.name}</h4>
              <span class="text-sm text-primary-600 font-medium">{testimonial.role}</span>
            </div>
          </div>
          <p class="text-slate-600 italic relative z-10">"{testimonial.text}"</p>
          
          <!-- Stars -->
          <div class="flex text-accent mt-6">
            {[1, 2, 3, 4, 5].map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
