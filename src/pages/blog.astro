---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Blog – Amigurumi SEO"
  description="Artículos, tutoriales y novedades sobre amigurumi y patrones de mascotas."
>
  <!-- ==================== HERO ==================== -->
  <!-- Cambiamos la paleta a tonos teal para un look más corporativo -->
  <section class="relative overflow-hidden bg-gradient-to-r from-teal-600 to-teal-800 py-24">
    <div class="container mx-auto px-4 text-center relative z-10">
      <h1 class="text-5xl md:text-6xl font-display font-extrabold text-white mb-6">
      Blog <span class="text-teal-300">Amigurumi SEO</span>
      </h1>
      <p class="text-xl text-teal-200 max-w-2xl mx-auto">
        Descubre tutoriales paso a paso, trucos de tejido y las últimas novedades para crear
        tus amigurumis favoritos.
      </p>
    </div>

    <!-- Decoración con círculos difuminados -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/4 left-1/4 w-80 h-80 bg-teal-500 rounded-full mix-blend-screen filter blur-3xl opacity-30"></div>
      <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-teal-700 rounded-full mix-blend-screen filter blur-3xl opacity-30"></div>
    </div>
  </section>

  <!-- ==================== MISIÓN / VISIÓN ==================== -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-display font-bold text-slate-900 text-center mb-12">
        Nuestra misión y visión
      </h2>
      <div class="grid md:grid-cols-2 gap-12">
        <div class="bg-white p-8 rounded-xl shadow-sm">
          <h3 class="text-2xl font-semibold text-teal-700 mb-4">Misión</h3>
          <p class="text-slate-600">
            Brindar patrones de amigurumi 100 % en español, fáciles de seguir y con imágenes paso a paso, para que cualquier persona pueda crear, vender y regalar sus propias piezas con confianza.
          </p>
        </div>
        <div class="bg-white p-8 rounded-xl shadow-sm">
          <h3 class="text-2xl font-semibold text-teal-700 mb-4">Visión</h3>
          <p class="text-slate-600">
            Convertirnos en la referencia líder en la comunidad hispanohablante de amigurumi, impulsando la creatividad y el emprendimiento a través de recursos de alta calidad y un soporte cercano.
          </p>
        </div>
      </div>

      <!-- CTA al final de la sección -->
      <div class="mt-16 text-center">
        <a
          href="/ebook-patrones-mascotas"
          class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold text-white bg-teal-700 rounded-full hover:bg-teal-600 transition-all shadow-md hover:shadow-lg transform hover:-translate-y-1"
        >
          🎁 Descarga el Ebook de 60 patrones (¡70 % de descuento!)
        </a>
      </div>
    </div>
  </section>
</Layout>